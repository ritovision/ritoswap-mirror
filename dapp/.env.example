#Prisma Postgres for tracking Colored Keys usage status
DATABASE_URL="your-database-url-for-tracking-colored-keys-usage-status"

# Cloudflare State worker (durable object)
NEXT_PUBLIC_ENABLE_STATE_WORKER=true
STATE_WORKER_API_KEY=
STATE_WORKER_URL=

# Active Chain Configuration -> Ethereum, Sepolia, Ritonet
NEXT_PUBLIC_ACTIVE_CHAIN=Sepolia

#RitoNet Localhost
NEXT_PUBLIC_LOCAL_CHAIN_ID=90999999
NEXT_PUBLIC_LOCAL_BLOCKCHAIN_NAME=RitoNet
NEXT_PUBLIC_LOCAL_BLOCKCHAIN_EXPLORER_URL=
NEXT_PUBLIC_LOCAL_BLOCKCHAIN_EXPLORER_NAME=RitoNet Explorer
NEXT_PUBLIC_LOCAL_BLOCKCHAIN_RPC=http://localhost:8545
NEXT_PUBLIC_LOCAL_BLOCKCHAIN_WSS=ws://localhost:8546

#RPC Endpoints
NEXT_PUBLIC_ALCHEMY_API_KEY=

#WalletConnect
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_APP_NAME=App Name
NEXT_PUBLIC_APP_DESCRIPTION=App Description

#Rango DEX Widget
NEXT_PUBLIC_RANGO_API_KEY=

#Email Configurations
BREVO_API_KEY=
SENDER_EMAIL=
RECEIVER_EMAIL=
USE_CLOUDFLARE_WORKER=false
CLOUDFLARE_WORKER_URL=

#Cloudflare R2
R2_API_ACCESS_KEY_ID=
R2_API_SECRET_ACCESS_KEY=
R2_API_BUCKET_NAME=
R2_API_ACCOUNT_ID=

#Service Worker for PWA
NEXT_PUBLIC_SW=true

#OpenAI
OPENAI_API_KEY=

# Pinecone Vector Database
PINECONE_API_KEY=

# Notification Controls
# Set to "false" to disable specific notification types
# Any other value or empty/missing will enable notifications by default
NEXT_PUBLIC_LOCAL_NOTIFICATIONS=

# Logger config
# debug | info | warn | error
LOG_LEVEL=debug  
SERVICE_NAME=
ENABLE_FILE_LOGS=
SHOW_TEST_LOGS=


# Backdoor configuration for api/form-submission-gateway using backdoorToken (for testing purposes)
# Setting this allows a specific token to be automatically reset after being successfully marked as "used" in the prisma database.
# A private key is needed to sign the request in either of the other test env files.
BACKDOOR_TOKEN=false
TOKEN_ID=
# Locks in a specific address to be used for the backdoor token, preventing others from using it even if they have the token.
BACKDOOR_ADDRESS=

VERCEL_ENV=development


#JWT (use pnpm secret:jwt to generate a secret)
JWT_ALG=HS256
JWT_SECRET=
JWT_AUD=localhost:3000
JWT_ACCESS_TTL=900
JWT_CLOCK_TOLERANCE=5

# Sentry
# Client DSN (public)
NEXT_PUBLIC_SENTRY_DSN=https://6cf223f274f2cb96b3fad5453dac172a@o4510327391715328.ingest.us.sentry.io/4510388576518144
# Optional server override (fallbacks to NEXT_PUBLIC_SENTRY_DSN if unset)
SENTRY_DSN=
# Optional environment tag (e.g. development | preview | production | mainnet | sepolia)
SENTRY_ENVIRONMENT=
# Optional source map upload (build-time only)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_RELEASE=
